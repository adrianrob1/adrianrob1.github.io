<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{ title if title else "Adrian Robert Minut" }}</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.jade.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css" />
    <style>
      /* Two-column layout: sidebar + content */
      .page-wrapper {
        display: grid;
        grid-template-columns: 210px 1fr;
        gap: 3rem;
        align-items: start;
        margin-top: 1.5rem;
      }

      /* Sticky sidebar */
      .sidebar {
        position: sticky;
        top: 2rem;
        text-align: center;
      }

      .sidebar-avatar {
        width: 150px;
        height: 150px;
        border-radius: 50%;
        object-fit: cover;
        margin-bottom: 0.85rem;
        border: 3px solid var(--pico-primary-border);
      }

      .sidebar-name {
        font-size: 1rem;
        font-weight: 700;
        margin: 0 0 0.2rem;
      }

      .sidebar-affiliation {
        font-size: 0.8rem;
        color: var(--pico-muted-color);
        line-height: 1.4;
        margin: 0 0 1rem;
      }

      /* Link list */
      .sidebar-links {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
        align-items: center;
      }

      .sidebar-links a {
        font-size: 0.85rem;
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        text-decoration: none;
      }

      .sidebar-links a:hover {
        text-decoration: underline;
      }

      /* Hide sidebar on mobile/tablet */
      @media (max-width: 992px) {
        .sidebar {
          display: none;
        }
        .page-wrapper {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <header class="container">
      {% include "nav.njk" %}
    </header>
    <main class="container">
      <div class="page-wrapper">
        <aside class="sidebar">
          <img
            src="/public/profile.jpg"
            alt="Adrian Robert Minut"
            class="sidebar-avatar"
          />
          <p class="sidebar-name">Adrian Robert Minut</p>
          <p class="sidebar-affiliation">
            PhD Student<br />
            <small>GLADIA &amp; OmnAI Labs</small><br />
            Sapienza University of Rome
          </p>
          <ul class="sidebar-links">
            <li>
              <a href="https://scholar.google.com/citations?user=BLmHVIwAAAAJ" target="_blank" rel="noopener">
                <!-- Scholar icon -->
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 24a7 7 0 1 1 0-14 7 7 0 0 1 0 14zm0-24L0 9.5l4.838 3.94A8 8 0 0 1 12 9a8 8 0 0 1 7.162 4.44L24 9.5z"/></svg>
                Google Scholar
              </a>
            </li>
            <li>
              <a href="https://github.com/adrianrob1" target="_blank" rel="noopener">
                <!-- GitHub icon -->
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
                GitHub
              </a>
            </li>
            <li>
              <a href="https://orcid.org/0009-0002-5418-0230" target="_blank" rel="noopener">
                <!-- ORCID icon -->
                <svg width="14" height="14" viewBox="0 0 256 256" fill="currentColor" aria-hidden="true"><path d="M128 0C57.3 0 0 57.3 0 128s57.3 128 128 128 128-57.3 128-128S198.7 0 128 0M86.3 186.2H70.9V79.1h15.4zm-7.7-122.9a9.9 9.9 0 0 1 0-19.8 9.9 9.9 0 0 1 0 19.8m107.1 122.9h-15.4v-53c0-12.9-.5-29.5-18-29.5-18 0-20.7 14-20.7 28.5v54h-15.4V79.1h14.8v16.1h.3c5.1-9.7 12.9-14.8 24.7-14.8 19.2 0 29.7 12.9 29.7 37.2z"/></svg>
                ORCID
              </a>
            </li>
          </ul>
        </aside>
        <div class="page-content">
          {{ content | safe }}
        </div>
      </div>
    </main>
    <footer class="container">
      <small>&copy; {% year %} Adrian Robert Minut</small>
    </footer>
  </body>
</html>
